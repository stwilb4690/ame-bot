# ============================================================
# AME Bot — Adaptive Market Engine
# Copy this to .env and fill in your values
# ============================================================

# ── Mode ─────────────────────────────────────────────────────
# APP_MODE: kalshi-only | monitor | full
#   kalshi-only  = Kalshi WebSocket only; same-platform arb monitoring
#   monitor      = Both WebSockets; cross-platform spread display, no execution
#   full         = Both WebSockets + cross-platform arb execution
APP_MODE=monitor

# APP_ENV: demo | prod
#   demo = use Kalshi demo environment (safe for testing)
#   prod = use Kalshi production environment
APP_ENV=demo

# Override Kalshi API host (overrides APP_ENV)
# KALSHI_API_HOST=trading-api.kalshi.com

# Dry run: no real orders placed (always on by default)
DRY_RUN=1

# ── Kalshi Credentials (required) ────────────────────────────
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi_private_key.pem

# Kalshi fee rate (0.0–1.0). Default 0.07 = 7%.
# Set to 0.0 if Kalshi has removed trading fees.
KALSHI_FEE_RATE=0.07

# ── Polymarket Credentials (optional; required for APP_MODE=full) ──
# POLY_PRIVATE_KEY=0xYourPrivateKeyHere
# POLY_FUNDER=0xYourWalletAddressHere

# ── Discovery ────────────────────────────────────────────────
# Force full market re-discovery (ignore cache)
FORCE_DISCOVERY=0

# Only monitor specific leagues (comma-separated, empty = all)
# ENABLED_LEAGUES=nhl,nba,nfl

# Extra Kalshi-only series to monitor (no Polymarket counterpart)
# These are Kalshi series tickers for Fed/econ/politics/crypto markets
KALSHI_EXTRA_SERIES=KXFED,KXCPI,KXBTC

# ── Telegram Alerts (optional) ───────────────────────────────
# Create a bot via @BotFather, then get your chat ID via @userinfobot
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=987654321

# Cooldown between repeated alerts for the same market+type (seconds)
ALERT_COOLDOWN_SECS=300

# ── Thresholds ───────────────────────────────────────────────
# Arb threshold: alert when YES+NO cost < this (0.995 = 0.5% profit floor)
# ARB_THRESHOLD=0.995

# Wide spread alert: fire when YES+NO round-trip exceeds 100¢ + this value
WIDE_SPREAD_THRESHOLD=10

# Enable per-market price logging (verbose)
PRICE_LOGGING=0

# ── Circuit Breaker ──────────────────────────────────────────
CB_MAX_POSITION_PER_MARKET=50000
CB_MAX_TOTAL_POSITION=100000
CB_MAX_DAILY_LOSS=500
CB_MAX_CONSECUTIVE_ERRORS=5
CB_COOLDOWN_SECS=300
CB_ENABLED=1

# ── State Files (Henrik integration) ────────────────────────
# How often (seconds) to write state/status.json and state/opportunities.json
STATE_WRITE_INTERVAL_SECS=10

# ── Diagnostic Mode ──────────────────────────────────────────
# DIAGNOSE=1       to enable (or pass --diagnose CLI flag)
# DIAGNOSE_SECS=60 how long to run before exiting
DIAGNOSE=0
DIAGNOSE_SECS=60

# ── Developer ────────────────────────────────────────────────
# TEST_ARB=1          inject a fake arb for testing execution flow
# TEST_ARB_TYPE=poly_yes_kalshi_no | kalshi_yes_poly_no
# RUST_LOG=ame_bot=debug  verbose logging
